@{
    Layout = null;
    ViewData["Title"] = "Admin Login";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LawTrack (v 0.1.5)</title>

    <!-- Font Awesome -->
    <link rel="stylesheet" href="~/plugins/fontawesome-free/css/all.min.css" asp-append-version="true" />

    <!-- AdminLTE -->
    <link rel="stylesheet" href="~/dist/css/adminlte.min.css" asp-append-version="true" />

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/AdminLogIn.css" asp-append-version="true" />

    <link rel="icon" href="~/Images/GENERAL/favicon32.png" />
    <link rel="icon" href="~/Images/GENERAL/favicon16.png" />

    <script src="~/plugins/jquery/jquery.min.js" asp-append-version="true"></script>
    <script src="~/plugins/bootstrap/js/bootstrap.bundle.min.js" asp-append-version="true"></script>
    <script src="~/dist/js/adminlte.min.js" asp-append-version="true"></script>
</head>

<partial name="ChangePassword" />

<body class="hold-transition login-page">

    <div class="login-box">
        <div class="d-flex justify-content-center">

            <!-- Logo -->
            <div class="login-logo-col mb-md-0 text-center">
                <img id="imgLogInLogo" src="~/Images/GENERAL/LawTrackLogoGoldTransparent.webp" class="login-logo-image" />
            </div>

        </div>

        <div class="card">
            <div class="card-body login-card-body">
                <div class="login-row align-items-center">

                    <div class="d-flex text-center justify-content-center">

                        <!-- Form -->
                        <div class="login-form-col text-left w-100">
                            <p class="text-left pl-0 text-white font-weight-bold">Log in to start your session</p>
                            <form method="post" id="loginForm" asp-controller="LogIn" asp-action="Index">
                                <div class="input-group mb-3">
                                    <input type="text" class="form-control" name="Username" placeholder="Username" autofocus>
                                    <div class="input-group-append">
                                        <div class="input-group-text text-white"><span class="fas fa-user"></span></div>
                                    </div>
                                </div>

                                <div class="input-group mb-3">
                                    <input type="password" class="form-control" name="Password" placeholder="Password">
                                    <div class="input-group-append">
                                        <div class="input-group-text text-white"><span class="fas fa-key"></span></div>
                                    </div>
                                </div>

                                <div class="row">

                                    <div class="col-6 d-flex align-items-center">
                                        <div class="text-white">
                                            <input type="checkbox" id="remember" name="RememberMe">
                                            <label class="font-weight-normal" for="remember">Remember Me</label>
                                        </div>
                                    </div>

                                    <div class="col-6 d-flex align-items-center">
                                        <button id="btnLogIn" type="button" class="btn btn-darkblue-gold w-100">
                                            <span class="btn-text">
                                                <i class="fas fa-sign-in-alt"></i> Log In
                                            </span>
                                             
                                        </button>
                                    </div>

                                </div>

                                @if (ViewBag.Error != null)
                                {
                                    <div class="row mt-2">
                                        <div class="col-12 text-danger text-center">@ViewBag.Error</div>
                                    </div>

                                }

                            </form>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
    @if (ViewData["ErrorHandling"] != null)
    {
        <div class="alert alert-danger error-handling">@ViewData["ErrorHandling"]</div>
    }
    <!-- Scripts -->

    <script>
         $(document).ready(function () {

            $('#btnLogIn').on('click', function () {

                let btn = $(this);
                let form = $('#loginForm');

                let username = $('input[name="Username"]');
                let password = $('input[name="Password"]');

                let hasError = false;

                // remove old errors
                $('.login-error').remove();
                $('.form-control').removeClass('is-invalid');

                // ========================
                // VALIDATION
                // ========================
                if (username.val().trim() === '') {
                    username.addClass('is-invalid');
                    hasError = true;
                }

                if (password.val().trim() === '') {
                    password.addClass('is-invalid');
                    hasError = true;
                }

                if (hasError) {
                    form.append(`
                        <div class="login-error text-danger text-center mt-2">
                            Please enter username and password
                        </div>
                    `);
                    return;
                }

                // ========================
                // SHOW SPINNER
                // ========================
                btn.prop('disabled', true).html(
                    '<span class="spinner-border spinner-border-sm"></span> Logging in...'
                );

                // ========================
                // AJAX
                // ========================
                let redirect = false;

                $.ajax({
                    url: '@Url.Action("LogIn", "LogIn")',
                    type: 'POST',
                    data: {
                        Username: username.val(),
                        Password: password.val(),
                        RememberMe: $('#remember').is(':checked')
                    },
                    dataType: 'json',

                    success: function (res) {

                        if (!res.success) {
                            form.append(`
                                <div class="login-error text-danger text-center mt-2">
                                    ${res.message}
                                </div>
                            `);
                            return;
                        }

                        // mark redirect
                        redirect = true;
                    },

                    error: function () {
                        form.append(`
                            <div class="login-error text-danger text-center mt-2">
                                Server error. Please try again.
                            </div>
                        `);
                    },

                    complete: function () {

                        if (redirect) {
                            // 🔥 KEEP spinner running until redirect
                            window.location.href = '/Home/Index';
                            return;
                        }

                        // only reset button if NOT redirecting
                        btn.prop('disabled', false).html(
                            '<i class="fas fa-sign-in-alt"></i> Log In'
                        );
                    }
                });

            });

            // ========================
            // REMOVE ERROR ON TYPE
            // ========================
            $('input[name="Username"], input[name="Password"]').on('input', function () {
                $(this).removeClass('is-invalid');
                $('.login-error').remove();
            });

            // ========================
            // ENTER KEY LOGIN
            // ========================
            $('#loginForm input').on('keypress', function (e) {
                if (e.which === 13) {
                    e.preventDefault();
                    $('#btnLogIn').click();
                }
            });

        });
     </script>
</body>
</html>
